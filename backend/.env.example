# Copy to .env. Devnet defaults match the verified Phase 0 spike.

PORT=8787

# Solana devnet RPC for the on-chain subscribe transaction.
RPC_URL=https://api.devnet.solana.com

# TxLINE host (auth + data). Devnet = txline-dev, mainnet = txline.
TXLINE_BASE=https://txline-dev.txodds.com

# Active-cluster program + TxL mint (devnet values; override for mainnet).
PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# Free World Cup / International tier. weeks MUST be a multiple of 4.
SERVICE_LEVEL_ID=1
DURATION_WEEKS=4

# Reuse the funded wallet from the spike so we do not re-fund.
WALLET_PATH=../spike/wallet-devnet.json

# Soccer / World Cup discovery (verified: CompetitionId 72, SportId 1).
WORLD_CUP_COMPETITION_ID=72

# AI co-commentator via Ollama Cloud. Without these the backend falls back to a
# deterministic line. Get a key at https://ollama.com.
OLLAMA_HOST=https://ollama.com
OLLAMA_KEY=
OLLAMA_MODEL=gpt-oss:120b-cloud
