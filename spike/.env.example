# Copy to .env and adjust if needed. All values have sane devnet defaults.

# Solana devnet RPC used to send the subscribe transaction.
RPC_URL=https://api.devnet.solana.com

# TxLINE auth host (guest/start + token/activate). Devnet = oracle-dev.
AUTH_BASE=https://oracle-dev.txodds.com

# TxLINE data host (fixtures/scores/odds). On devnet the official examples
# serve data from oracle-dev too; override to txline-dev if needed.
DATA_BASE=https://oracle-dev.txodds.com

# Free World Cup / International tier. Devnet only offers Level 1 (60s sampled).
SERVICE_LEVEL_ID=1
DURATION_WEEKS=1

# Path to a devnet keypair JSON (Solana CLI format: array of 64 ints).
# If the file does not exist, the probe generates one here and airdrops SOL.
WALLET_PATH=./wallet-devnet.json
